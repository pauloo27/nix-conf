input {
    focus-follows-mouse max-scroll-amount="0%"

    keyboard {
        xkb {
            layout "us"
            variant "altgr-intl"
        }

        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {
    }

    trackpoint {
    }

    tablet {
        map-to-output "DP-1"
    }

    touch {
        map-to-output "DP-1"
    }
}
